# Forest eOffice Backend — Environment Variables
# Copy this file to .env and fill in your values for local development.
# On Railway, set these directly in the Railway dashboard under Variables.
#
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: Railway provides DATABASE_URL automatically when you add a PostgreSQL
# plugin to your service — you do NOT need to set it manually on Railway.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# 64-character random secret key for JWT signing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FOREST_EOFFICE_SECRET_KEY=change-me-to-a-random-64-char-string

# Database connection URL.
# Local SQLite (default):
FOREST_EOFFICE_DATABASE_URL=sqlite:///./data/app.db
# PostgreSQL example:
# FOREST_EOFFICE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Allowed CORS origins. Accepts a comma-separated list OR a JSON array.
# Examples:
#   FOREST_EOFFICE_CORS_ORIGINS_STR=http://localhost:5173
#   FOREST_EOFFICE_CORS_ORIGINS_STR=https://myapp.railway.app,http://localhost:5173
#   FOREST_EOFFICE_CORS_ORIGINS_STR=["https://myapp.railway.app","http://localhost:5173"]
FOREST_EOFFICE_CORS_ORIGINS_STR=http://localhost:5173

# ── Optional ─────────────────────────────────────────────────────────────────

# Gemini API key for the AI chatbot. Leave empty to use the rule-based fallback.
FOREST_EOFFICE_GEMINI_API_KEY=your-gemini-api-key-here

# Rate limiting (slowapi format)
FOREST_EOFFICE_RATE_LIMIT_LOGIN=5/minute
FOREST_EOFFICE_RATE_LIMIT_GLOBAL=100/minute

# JWT token expiry in minutes (default: 480 = 8 hours)
FOREST_EOFFICE_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Logging level: DEBUG | INFO | WARNING | ERROR
FOREST_EOFFICE_LOG_LEVEL=INFO
